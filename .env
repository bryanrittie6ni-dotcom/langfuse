# =============================================================================
# Langfuse 自托管部署配置文件
# 使用方式：
#   docker compose -f docker-compose.yml up -d
#   docker compose 会自动读取同级目录的这个 .env 文件
#
# 每个变量的用途和修改方式见下方注释
# 标记 ⚠️ 的为必改项（已生成临时密钥，部署前请替换为自己的）
# 标记 🔧 的为可选修改
# =============================================================================


# =============================================================================
# 1. 数据库连接（PostgreSQL）
# =============================================================================
# 必需。如果使用了 docker-compose.yml 自带 postgres 容器且没改密码，这里不用改
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL="postgresql://postgres:postgres5432@postgres:5432/postgres"   # 🔧 生产环境请改密码


# =============================================================================
# 2. 安全密钥（⚠️ 必须修改，已临时生成）
# =============================================================================

# ⚠️ NextAuth 会话加密密钥，用于加密登录 Cookie/JWT
# 生成方式: openssl rand -hex 32
NEXTAUTH_SECRET="f0f89a225ddbf7e8fdde9e2f001c2cec3bbf955cf739b784f6e2e9be1c3f9471"

# ⚠️ API Key 哈希盐值，用于哈希存储用户 API Key（不可逆）
# 生成方式: openssl rand -hex 32
SALT="015e2d1be3caae6018d5130e88180a824f7cb24450ba7fb8051f00a7948504a4"

# ⚠️ 数据加密密钥，用于加密敏感数据（如 LLM API Key、数据库凭证等）
# 必须是 64 个十六进制字符（256 位）
# 生成方式: openssl rand -hex 32
# 警告：部署后不要修改，否则已加密数据无法解密！
ENCRYPTION_KEY="9be8ff574c4dc2866f9203c6d8853b71bf52fa31e13a7a4d6e9ebdeb534ea0cf"

# 🔧 应用访问地址（用户浏览器访问 Langfuse 的 URL）
NEXTAUTH_URL="http://localhost:3000"


# =============================================================================
# 3. ClickHouse（分析数据库）
# =============================================================================
# 必需。如果使用 docker-compose.yml 自带 clickhouse 容器且没改密码，这里不用改
CLICKHOUSE_URL="http://clickhouse:8123"
CLICKHOUSE_USER="clickhouse"
CLICKHOUSE_PASSWORD="clickhouse8123"         # ⚠️ 生产环境请改密码
CLICKHOUSE_CLUSTER_ENABLED="false"       # 单机部署设为 false


# =============================================================================
# 4. Redis（消息队列 + 缓存）
# =============================================================================
# 必需。如果使用 docker-compose.yml 自带 redis 容器且没改密码，这里不用改
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_AUTH="myredissecret6379"              # ⚠️ 生产环境请改密码


# =============================================================================
# 5. S3 兼容存储（事件、媒体文件、批量导出）
# =============================================================================
# 默认使用 docker-compose.yml 自带的 MinIO 容器
# 如果使用外部 S3（如阿里云 OSS、AWS S3），修改对应的 ENDPOINT/REGION/KEY

# --- 事件存储（所有 SDK 上报的 trace 数据先存这里）---
LANGFUSE_S3_EVENT_UPLOAD_BUCKET="langfuse"
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT="http://minio:9000"
LANGFUSE_S3_EVENT_UPLOAD_REGION="us-east-1"
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID="minio"
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY="miniosecret8123"  # ⚠️ 生产环境请改
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE="true"           # MinIO 必须设为 true
LANGFUSE_S3_EVENT_UPLOAD_PREFIX="events/"

# --- 媒体存储（用户上传的图片、附件等）---
LANGFUSE_S3_MEDIA_UPLOAD_BUCKET="langfuse"
LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT="http://localhost:9090"
LANGFUSE_S3_MEDIA_UPLOAD_REGION="us-east-1"
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID="minio"
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY="miniosecret"  # ⚠️ 生产环境请改
LANGFUSE_S3_MEDIA_UPLOAD_FORCE_PATH_STYLE="true"
LANGFUSE_S3_MEDIA_UPLOAD_PREFIX="media/"

# --- 批量导出存储（数据导出功能）---
LANGFUSE_S3_BATCH_EXPORT_ENABLED="false"                            # 不需要导出功能可不开启
LANGFUSE_S3_BATCH_EXPORT_BUCKET="langfuse"
LANGFUSE_S3_BATCH_EXPORT_ENDPOINT="http://minio:9000"
LANGFUSE_S3_BATCH_EXPORT_REGION="us-east-1"
LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID="minio"
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY="miniosecret"
LANGFUSE_S3_BATCH_EXPORT_FORCE_PATH_STYLE="true"
LANGFUSE_S3_BATCH_EXPORT_PREFIX="exports/"


# =============================================================================
# 6. 邮件配置（可选，用于密码重置、邀请等）
# =============================================================================
# 不配也能跑，但用户收不到邮件通知
# SMTP 格式: smtp://用户名:密码@主机:端口 或 smtps://...
# AWS SES 格式: ses://us-east-1
# EMAIL_FROM_ADDRESS="langfuse@your-domain.com"
# SMTP_CONNECTION_URL="smtp://user:pass@smtp.example.com:587"


# =============================================================================
# 7. 初始化自动创建（首次部署建议开启，省去手动创建组织/项目的步骤）
# =============================================================================
# 🔧 取消注释并修改为你的信息，启动时会自动创建组织、项目和用户
# LANGFUSE_INIT_ORG_ID="my-org"
# LANGFUSE_INIT_ORG_NAME="My Organization"
# LANGFUSE_INIT_PROJECT_ID="my-project"
# LANGFUSE_INIT_PROJECT_NAME="My Project"
# LANGFUSE_INIT_USER_EMAIL="admin@your-domain.com"
# LANGFUSE_INIT_USER_NAME="Admin"
# LANGFUSE_INIT_USER_PASSWORD="changeme123"


# =============================================================================
# 8. 功能开关（可选）
# =============================================================================
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES="false"   # 是否启用实验性功能
TELEMETRY_ENABLED="true"                        # 是否允许匿名遥测（建议保留，帮助项目改进）
LANGFUSE_ENABLE_BLOB_STORAGE_FILE_LOG="true"    # 是否记录 blob 存储日志
AUTH_DISABLE_SIGNUP="false"                     # 设为 true 禁止用户自行注册


# =============================================================================
# 9. 日志（可选）
# =============================================================================
# LANGFUSE_LOG_LEVEL="info"    # trace | debug | info | warn | error | fatal
# LANGFUSE_LOG_FORMAT="text"   # text | json


# =============================================================================
# 10. 性能调优（可选，保持默认即可正常运行）
# =============================================================================
# LANGFUSE_INGESTION_QUEUE_DELAY_MS="15000"     # 数据写入延迟，越大写入越不频繁，但延迟越高
# LANGFUSE_CACHE_PROMPT_ENABLED="true"           # 是否缓存 Prompt
# LANGFUSE_CACHE_PROMPT_TTL_SECONDS="3600"       # Prompt 缓存时间
